# =============================================================================
# TaskFlow - Backend Environment Variables (Exemplo)
# =============================================================================
# Copie este arquivo para .env e preencha com suas credenciais reais.
# NUNCA commite o arquivo .env com dados sensíveis!
# =============================================================================

# URL de conexão com o banco de dados PostgreSQL (Neon)
# Substitua pelos seus dados reais
DATABASE_URL=postgresql://usuario:senha@host:porta/nome_banco?sslmode=require

# Porta onde o servidor backend será executado
PORT=5000